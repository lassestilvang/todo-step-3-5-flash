#!/usr/bin/env sh
. "$(dirname -- "$0")/_/husky.sh"

echo "🔍 Running pre-commit checks..."

# Run lint-staged first to fix formatting and lint issues
echo "📝 Running lint-staged..."
bun run lint-staged
lint_staged_exit=$?

if [ $lint_staged_exit -ne 0 ]; then
  echo "❌ lint-staged failed. Please fix the issues and try again."
  exit $lint_staged_exit
fi

# Then run typecheck on the fixed code
echo "🔎 Running typecheck..."
bun run typecheck
typecheck_exit=$?

if [ $typecheck_exit -ne 0 ]; then
  echo "❌ Typecheck failed. Please fix type errors and try again."
  exit $typecheck_exit
fi

echo "✅ All pre-commit checks passed!"
